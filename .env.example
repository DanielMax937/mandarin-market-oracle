ORACLE_ENV=development
ORACLE_EXECUTION_MODE=paper
ORACLE_PROVENANCE_NETWORK=arc-testnet
ORACLE_BANKROLL_USDC=10000
ORACLE_MAX_POSITION_PCT=0.05
ORACLE_ALLOW_REAL_ORDERS=false
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# Required in restricted networks when calling Polymarket APIs.
# Example: http://127.0.0.1:7890
POLYMARKET_PROXY_URL=
ORACLE_REQUEST_TIMEOUT_SECONDS=12

# Arc proof writer.
# evm: verify ARC_RPC_URL and submit proof payload to a deployed registry when ARC_PRIVATE_KEY is set.
ARC_PROOF_MODE=evm
ARC_RPC_URL=
ARC_REASONING_REGISTRY_ADDRESS=
ARC_EXPLORER_BASE_URL=
# Use a testnet-only throwaway key. Never commit it.
ARC_PRIVATE_KEY=

# OpenAI-compatible LLM reasoning agent.
# Keep real values in .env.local only.
ORACLE_LLM_REASONING_ENABLED=true
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
